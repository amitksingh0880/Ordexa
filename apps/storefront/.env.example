# Base URL of the backend API. For local dev this is the local backend;
# on Render set it to the deployed backend's URL (e.g. https://ordexa-backend.onrender.com).
VITE_API_URL=http://localhost:5000

# Razorpay public test key (e.g. rzp_test_xxxxxxxx). Leave blank to use the
# built-in mock payment gateway (no real charge).
VITE_RAZORPAY_KEY_ID=
