# ── Core ─────────────────────────────────────────────────────────────────────
# MongoDB connection string (Render injects this from the managed database).
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/ordexa?retryWrites=true&w=majority"
# HTTP port (Render injects PORT automatically).
PORT=5000
NODE_ENV=development

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
# Leave OTEL_EXPORTER_OTLP_ENDPOINT unset to disable telemetry (default on
# Render free tier). Set it to a collector/SaaS OTLP endpoint to enable.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ordexa-backend

# ── Temporal (optional) ──────────────────────────────────────────────────────
# Leave TEMPORAL_ADDRESS unset to run the DB-durable in-process saga (default on
# Render free tier). Set it (e.g. localhost:7233) to drive
# orders through the durable Temporal workflow + worker.
# TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=orders
