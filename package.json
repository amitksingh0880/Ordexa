{
  "name": "ordexa",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "docs": "typedoc",
    "docs:deploy": "bun run docs && bunx gh-pages -d docs/backend",
    "e2e": "playwright test --config apps/e2e/playwright.config.ts",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --apply",
    "openapi:lint": "bunx @redocly/cli lint apps/backend/spec/index.yml",
    "tsc": "bun run tsc:backend && bun run tsc:admin && bun run tsc:storefront",
    "tsc:backend": "bunx tsc -p apps/backend/tsconfig.json --noEmit",
    "tsc:admin": "bunx tsc -p apps/admin/tsconfig.app.json --noEmit",
    "tsc:storefront": "bunx tsc -p apps/storefront/tsconfig.app.json --noEmit",
    "check": "bun run openapi:lint && bun run lint && bun run tsc",
    "prepare": "husky install",
    "storybook": "npx storybook dev -p 6006",
    "storybook:build": "npx storybook build -c apps/admin/.storybook -o apps/admin/storybook-static",
    "storybook:deploy": "npm run storybook:build && npx gh-pages -d apps/admin/storybook-static"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.54.1",
    "@redocly/openapi-core": "^1.34.3",
    "@types/bun": "latest",
    "@types/node": "^24.0.13",
    "bun-types": "^1.2.18",
    "eslint": "^9.30.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "gh-pages": "^6.3.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.1.2",
    "openapi-typescript": "^7.8.0",
    "ts-pattern": "^5.7.1",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.7",
    "wait-on": "^8.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "bunx biome check --apply --noEmit"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^14.1.1",
    "mongodb": "^7.4.0",
    "openapi-backend": "^5.13.0"
  }
}
